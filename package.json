{
  "name": "@mtrenker/pi-clean",
  "version": "0.1.0",
  "description": "Custom pi package",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git@github.com:mtrenker/pi-clean.git"
  },
