{
  "baseUrl": "http://localhost:8880",
  "speakPath": "/v1/audio/speech",
  "speakMethod": "POST",
  "requestEncoding": "json",
  "responseMode": "binary",
  "binaryFileExtension": "mp3",
  "textField": "input",
  "voiceField": "voice",
  "defaultVoice": "af_heart",
  "extraBody": {
    "model": "kokoro",
    "response_format": "mp3",
    "speed": 1.0,
    "stream": false
  },
  "stopBody": {},
  "headers": {},
  "charLimit": 200,
  "dedupeWindowMs": 10000,
  "autoPlay": true,
  "playerCommand": "ffplay",
  "playerArgs": ["-nodisp", "-autoexit", "-loglevel", "error"]
}
